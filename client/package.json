{
  "name": "adme-client",
  "version": "3.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:dev": "ng serve --configuration=development",
    "build": "ng build",
    "build:production": "ng build --configuration=production",
    "build:embedded": "ng build --configuration=production --base-href=/ && rimraf ../server/client && cpx \"dist/adme-client/browser/**/*\" ../server/client -u",
    "build:embedded:adme": "ng build --configuration=production --base-href=/adme/ && rimraf ../server/client && cpx \"dist/adme-client/browser/**/*\" ../server/client -u",
    "watch": "ng build --watch --configuration=development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.1",
    "swagger-ui-dist": "^5.11.0",
    "tslib": "^2.6.2",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "cpx": "^1.5.0",
    "jasmine-core": "~5.1.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.9.0"
  }
}

