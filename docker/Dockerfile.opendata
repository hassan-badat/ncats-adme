# Dockerfile for OpenData subdomain deployment (opendata.ncats.nih.gov/adme)
# Full stack with Angular frontend and Flask backend
#
# Usage:
#   docker build -f docker/Dockerfile.opendata -t ncats-adme-opendata .
#   docker run -p 5000:5000 ncats-adme-opendata

FROM node:20 AS build

WORKDIR /opt/adme

COPY client ./

RUN npm install && npm install -g @angular/cli

# Build parameter for opendata subdomain
ENV NODE_OPTIONS=--openssl-legacy-provider
RUN ng build --configuration production --deploy-url=/adme/client/ --base-href=/adme

FROM continuumio/miniconda3:24.11.1-0

# Install required packages
RUN apt-get update && apt-get install -y iproute2 && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/adme

COPY server ./
COPY server/predictors/functions_for_cytosol.py ./functions_for_cytosol.py

# Use libmamba solver for faster dependency resolution
RUN conda config --set solver libmamba && \
    conda env create -f environment.yml && \
    conda clean -afy

ENV PATH /opt/conda/envs/ncats-adme/bin:$PATH
ENV PYTHONPATH=/opt/adme/predictors:${PYTHONPATH}

RUN chmod +x startup.sh

# Clean existing client folder
RUN rm -rf client
COPY --from=build /opt/adme/dist/client client

CMD /bin/bash startup.sh

EXPOSE 5000

